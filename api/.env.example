PORT=3001
# 生产环境必须设置为 production，此时 CORS 只允许 ALLOWED_ORIGINS 中的来源
NODE_ENV=development
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# 可选：分任务选模型（不配则回退到 AI_MODEL）。解析用便宜模型，优化用更强模型。
# AI_PARSE_MODEL=gpt-4o-mini
# AI_OPTIMIZE_MODEL=gpt-4o
# 可选：单次生成最大 token 数（避免长简历输出被截断成坏 JSON）
AI_MAX_TOKENS=4096
# 可选：单次 LLM 调用超时（毫秒）
AI_TIMEOUT_MS=60000
# CORS 白名单：生产环境必须配置，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=3600000

# 简易后台：生产环境必须配置，访问 /admin 时填写账号和密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
# 可选：兼容机器访问或临时脚本访问，设置后也可用 x-admin-token 请求统计接口
# ADMIN_TOKEN=change_me

# 埋点事件本地存储目录，默认 api/data
ANALYTICS_DATA_DIR=./data
# 可选：IP hash 盐值，生产环境建议设置为随机长字符串
ANALYTICS_IP_SALT=change_me
